# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- OpenAI (required) ---
# Used for the LLM agents (gpt-4o-mini) and ChromaDB embeddings (text-embedding-3-small)
OPENAI_API_KEY=your-openai-api-key-here

# --- LangSmith tracing (optional) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=change-order-agent

# --- Storage paths (optional — defaults shown) ---
CHROMA_PERSIST_DIR=./chroma_data
AUDIT_DB_PATH=./audit.db
CHECKPOINT_DB_PATH=./checkpoints.db
